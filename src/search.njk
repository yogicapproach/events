<script>
(function() {
  var nl = (navigator.language || 'es').toLowerCase();
  var lang = nl.startsWith('ne') ? 'ne' : nl.startsWith('en') ? 'en' : 'es';
  var p = new URLSearchParams(location.search).get('lang');
  if (p === 'en' || p === 'es' || p === 'ne') lang = p;
  location.replace('/events/2026-uruguay/' + lang + '/search/');
})();
</script>
