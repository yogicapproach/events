<!DOCTYPE html>
<html lang="{{ lang | default('es') }}">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{% block page_title %}{{ title }}{% if title %} | {% endif %}Yogaval 2026{% endblock %}</title>
  <meta name="description" content="{% block meta_description %}{{ description | default('Talks by Satchidananda — Uruguay, February 2026. Transcripts in English, Spanish, and Nepali.') }}{% endblock %}">
  <meta name="author" content="Satchidananda">
  <meta property="og:type" content="website">
  <meta property="og:title" content="{% block og_title %}{{ ogTitle | default(title) }}{% if ogTitle or title %} | {% endif %}Yogaval 2026{% endblock %}">
  <meta property="og:description" content="{% block og_description %}{{ description | default('Talks by Satchidananda — Uruguay, February 2026.') }}{% endblock %}">
  <meta property="og:url" content="{{ site.baseUrl }}{{ ogUrl | default(page.url) }}">
  <meta property="og:image" content="{{ ogImage | default(site.ogImage) }}">
  <meta name="twitter:card" content="summary">
  <meta name="twitter:title" content="{% block twitter_title %}{{ ogTitle | default(title) }}{% if ogTitle or title %} | {% endif %}Yogaval 2026{% endblock %}">
  <meta name="twitter:description" content="{% block twitter_description %}{{ description | default('Talks by Satchidananda — Uruguay, February 2026.') }}{% endblock %}">
  <meta name="twitter:image" content="{{ ogImage | default(site.ogImage) }}">
  <link rel="preconnect" href="https://cdn.jsdelivr.net">
  <link rel="preconnect" href="https://docs.google.com">
  <link rel="preconnect" href="https://gc.zgo.at">
  <link rel="icon" type="image/x-icon" href="/2026-uruguay/favicon.ico">
  <link rel="icon" type="image/png" sizes="32x32" href="/2026-uruguay/favicon.png">
  <link rel="apple-touch-icon" sizes="180x180" href="/2026-uruguay/apple-touch-icon.png">
  {# marked.js kept for runtime needs (loadResources audio players, etc.) #}
  <script src="https://cdn.jsdelivr.net/npm/marked@15.0.4/marked.min.js"></script>
  {# shared.css — same file as used by the legacy docs/ site #}
  <link rel="stylesheet" href="/2026-uruguay/events/shared.css">
  {# Supplemental styles for Eleventy-specific HTML (lang-btn <a> elements, etc.) #}
  <link rel="stylesheet" href="/2026-uruguay/assets/eleventy-extra.css">
  {% block head_extra %}{% endblock %}
</head>
<body>
  {# Topbar (#topbar div) is injected at DOMContentLoaded by shared.js.
     It contains: site credit, feedback link, report-issue link, GoatCounter. #}
  <a href="#content" class="skip-nav">Skip to content</a>
  {% block header %}
  <header data-pagefind-ignore>
    <h1>{{ heading | default("Yogaval 2026") }}</h1>
    <p id="header-subtitle">{{ subtitle | safe }}</p>
  </header>
  {% endblock %}

  {% block body %}{{ content | safe }}{% endblock %}

  {% block footer %}
  <footer data-pagefind-ignore>
    <a id="footer-nav" href="{{ footerNavHref | default('/2026-uruguay/' + (lang | default('es')) + '/') }}">{{ footerNavLabel | safe }}</a>
    {# site-credit is also updated by shared.js updateTopbar() — static fallback below #}
    <div id="site-credit" class="site-credit">
      {%- if (lang | default('es')) == "ne" -%}
        <a href="https://yogicapproach.com" target="_blank" rel="noopener">YogicApproach</a> बाट 🧠❤️🙏 सँग बनाएको
      {%- elif (lang | default('es')) == "es" -%}
        Hecho con 🧠❤️🙏 por <a href="https://yogicapproach.com" target="_blank" rel="noopener">YogicApproach</a>.
      {%- else -%}
        Made with 🧠❤️🙏 by <a href="https://yogicapproach.com" target="_blank" rel="noopener">YogicApproach</a>.
      {%- endif -%}
    </div>
  </footer>
  {% endblock %}

  <script src="/2026-uruguay/events/shared.js"></script>
  {% block scripts %}{% endblock %}
</body>
</html>
