{% extends "layouts/base.njk" %}

{% block head_extra %}
<style>
  /* Resources section starts hidden; shared.js shows it once populated */
  #resources-section { display: none; }
</style>
{% endblock %}

{% block body %}
  {# ── Other-talks selector ─────────────────────────────────────────────── #}
  <div id="other-talks">
    <span id="other-talks-label" data-href="/2026-uruguay/{{ lang }}/">
      {%- if lang == "ne" -%}अर्को चर्चा <a href="/2026-uruguay/{{ lang }}/">छान्नुहोस्</a>:
      {%- elif lang == "es" -%}Ver <a href="/2026-uruguay/{{ lang }}/">otra charla</a>:
      {%- else -%}Select <a href="/2026-uruguay/{{ lang }}/">another talk</a>:
      {%- endif -%}
    </span>
    <select id="talk-select" aria-label="Select a talk" onchange="handleTalkSelect(this)">
      <option value="">
        {%- if lang == "ne" %}-- छान्नुहोस् --{%- elif lang == "es" %}-- Elegir --{%- else %}-- Choose --{%- endif -%}
      </option>
      {# Synthesis option #}
      <option value="/2026-uruguay/{{ lang }}/">
        {%- if lang == "ne" -%}सबै कुराहरूको सारांश — सबै चर्चाका मुख्य विचार
        {%- elif lang == "es" -%}Resumen de Charlas — Informe IA de ideas principales de todas las charlas
        {%- else -%}Summary of Talks — AI-generated report of main ideas from all the talks
        {%- endif -%}
      </option>
      {# Other talks, excluding the current one #}
      {% for ev in events %}
        {% if ev.folder !== talkFolder %}
        <option value="/2026-uruguay/{{ lang }}/{{ ev.folder }}/">{% eventLabel ev, lang %}</option>
        {% endif %}
      {% endfor %}
      {# Glossary — opens in new tab via handleTalkSelect() #}
      <option value="/2026-uruguay/{{ lang }}/glossary/" data-newtab="true">
        {%- if lang == "ne" -%}शब्दावली — योग र संस्कृत शब्दहरूको परिभाषा
        {%- elif lang == "es" -%}Glosario de Términos — Definiciones de términos del yoga y sánscrito
        {%- else -%}Glossary of Terms — Definitions of yoga and Sanskrit terms
        {%- endif -%}
      </option>
    </select>
  </div>

  {# ── Language toggle — hard <a> links, no JS required ───────────────── #}
  <div class="lang-toggle">
    <a href="/2026-uruguay/en/{{ talkFolder }}/"
       class="lang-btn{% if lang == 'en' %} active{% endif %}"
       role="button"
       aria-pressed="{{ 'true' if lang == 'en' else 'false' }}"
       id="btn-en">English<span class="lang-sublabel">Original</span></a>
    <a href="/2026-uruguay/es/{{ talkFolder }}/"
       class="lang-btn{% if lang == 'es' %} active{% endif %}"
       role="button"
       aria-pressed="{{ 'true' if lang == 'es' else 'false' }}"
       id="btn-es">Español<span class="lang-sublabel">IA Traducido</span></a>
    <a href="/2026-uruguay/ne/{{ talkFolder }}/"
       class="lang-btn{% if lang == 'ne' %} active{% endif %}"
       role="button"
       aria-pressed="{{ 'true' if lang == 'ne' else 'false' }}"
       id="btn-ne">नेपाली<span class="lang-sublabel">AI अनुवादित</span></a>
  </div>

  {# ── Resources section (populated at runtime by shared.js loadResources()) #}
  {# resources.json is served from this page's path (/[lang]/events/[folder]/)  #}
  {# and contains back-relative file paths pointing to /events/[folder]/resources/ #}
  <section id="resources-section">
    <div class="resources-heading"></div>
    <div id="resources-audio"></div>
    <div id="resources-pdfs"></div>
  </section>

  {# ── Pre-rendered transcript content ─────────────────────────────────── #}
  <div id="content">
    {{ transcriptHtml | safe }}
  </div>

  {# ── Image modal ─────────────────────────────────────────────────────── #}
  <div id="img-modal" onclick="this.classList.remove('open')">
    <img id="img-modal-img" src="" alt="">
  </div>
{% endblock %}

{% block scripts %}
<script>
(function () {
  var lang = "{{ lang }}";

  document.addEventListener("DOMContentLoaded", function () {
    // Update topbar feedback/report links for current language
    if (typeof updateTopbar === "function") {
      // Set _currentProgram so the feedback form pre-fills the talk name
      window._currentProgram = "{{ ev.date }} \u2014 {{ ev.location }} \u2014 {% if lang == 'ne' %}{{ ev.title_short_ne }}{% elif lang == 'es' %}{{ ev.title_short_es }}{% else %}{{ ev.title_short }}{% endif %}";
      updateTopbar(lang);
    }
    // Load resources section (audio, PDFs) — reads resources.json from current URL path
    if (typeof loadResources === "function") {
      loadResources(lang);
    }
  });
})();
</script>
{% endblock %}
