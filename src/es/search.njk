---
layout: false
lang: es
permalink: /2026-uruguay/es/search/
title: "Buscar"
heading: "Buscar en las charlas"
description: "Buscar en las transcripciones de las charlas de Satchidananda — Uruguay, febrero 2026."
footerNavHref: /events/2026-uruguay/es/
footerNavLabel: "&#8592; Ver todas las charlas"
---
{% extends "layouts/base.njk" %}

{% block head_extra %}
<link href="{{ '/2026-uruguay/pagefind/pagefind-ui.css' | url }}" rel="stylesheet">
<style>
  #search { max-width: 800px; margin: 1.5em auto; }
  .search-lang-filters { max-width: 800px; margin: 0 auto 1em; display: flex; gap: 0.5em; flex-wrap: wrap; align-items: center; }
  .search-lang-filters span { font-size: 0.9em; color: #555; margin-right: 0.25em; }
</style>
{% endblock %}

{% block body %}
  <div class="search-lang-filters" data-pagefind-ignore>
    <span>Filtrar por idioma:</span>
    <a class="lang-btn"        aria-pressed="false" href="{{ siteRoot }}/2026-uruguay/en/search/">English</a>
    <a class="lang-btn active" aria-pressed="true"  href="{{ siteRoot }}/2026-uruguay/es/search/">Español</a>
    <a class="lang-btn"        aria-pressed="false" href="{{ siteRoot }}/2026-uruguay/ne/search/">नेपाली</a>
  </div>
  <div id="search" data-pagefind-ignore></div>
{% endblock %}

{% block scripts %}
<script src="{{ '/2026-uruguay/pagefind/pagefind-ui.js' | url }}"></script>
<script>
  window.addEventListener('DOMContentLoaded', function() {
    new PagefindUI({
      element: '#search',
      baseUrl: '{{ siteRoot }}/',
      showImages: false,
      filters: { language: 'es' }
    });
    if (typeof updateTopbar === 'function') updateTopbar('es');
  });
</script>
{% endblock %}
