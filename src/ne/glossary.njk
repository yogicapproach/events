    <option value="{{ siteRoot }}/2026-uruguay/ne/{{ ev.folder }}/">{% eventLabel ev, "ne" %}</option>
    {% endfor %}
  </select>
</div>

{# ── Language toggle ─────────────────────────────────────────────────────── #}
