{% extends "layouts/base.njk" %}

{% block head_extra %}
<link href="{{ '/2026-uruguay/pagefind/pagefind-ui.css' | url }}" rel="stylesheet">
<style>
  #search { max-width: 800px; margin: 1.5em auto; }
  .search-lang-filters { max-width: 800px; margin: 0 auto 1em; display: flex; gap: 0.5em; flex-wrap: wrap; align-items: center; }
  .search-lang-filters span { font-size: 0.9em; color: #555; margin-right: 0.25em; }
</style>
{% endblock %}

{% block body %}
  <div class="search-lang-filters" data-pagefind-ignore>
    <span>भाषा छान्नुहोस्:</span>
    <a class="lang-btn"        aria-pressed="false" href="/en/events/2026-uruguay/search/">English</a>
    <a class="lang-btn"        aria-pressed="false" href="/es/events/2026-uruguay/search/">Español</a>
    <a class="lang-btn active" aria-pressed="true"  href="/ne/events/2026-uruguay/search/">नेपाली</a>
  </div>
  <div id="search" data-pagefind-ignore></div>
{% endblock %}

{% block scripts %}
<script src="{{ '/2026-uruguay/pagefind/pagefind-ui.js' | url }}"></script>
<script>
  window.addEventListener('DOMContentLoaded', function() {
    new PagefindUI({
      element: '#search',
      baseUrl: '/',
      showImages: false,
      filters: { language: 'ne' },
      translations: { placeholder: 'खोज्नुहोस्...' }
    });
    if (typeof updateTopbar === 'function') updateTopbar('ne');
  });
</script>
{% endblock %}
