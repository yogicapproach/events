  <a href="{{ siteRoot }}/2026-uruguay/en/" class="lang-btn" role="button" id="btn-en">English<span class="lang-sublabel">Original</span></a>
  <a href="{{ siteRoot }}/2026-uruguay/es/" class="lang-btn" role="button" id="btn-es">Español<span class="lang-sublabel">IA Traducido</span></a>
