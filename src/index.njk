<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <title>{{ site.title }} — Redirecting…</title>
  <link rel="canonical" href="/2026-uruguay/es/">
</head>
<body>
<script>
(function() {
  var nl = (navigator.language || navigator.userLanguage || 'es').toLowerCase();
  var lang = nl.startsWith('ne') ? 'ne' : nl.startsWith('en') ? 'en' : 'es';
  var dest = '{{ siteRoot }}/2026-uruguay/' + lang + '/';
  // honour legacy ?lang= param if present
  var p = new URLSearchParams(location.search).get('lang');
  if (p === 'en' || p === 'es' || p === 'ne') { lang = p; dest = '{{ siteRoot }}/2026-uruguay/' + lang + '/'; }
  location.replace(dest);
})();
</script>
<noscript><meta http-equiv="refresh" content="0; url={{ siteRoot }}/2026-uruguay/es/"></noscript>
  <p>Redirecting to <a href="{{ siteRoot }}/2026-uruguay/es/">Español</a>…</p>
</body>
</html>
