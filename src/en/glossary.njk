{# ── Other-talks selector ───────────────────────────────────────────────── #}
<div id="other-talks">
  <span id="other-talks-label" data-href="{{ siteRoot }}/2026-uruguay/en/">Select <a href="{{ siteRoot }}/2026-uruguay/en/">a talk</a>:</span>
  <select id="talk-select" aria-label="Select a talk" onchange="handleTalkSelect(this)">
    <option value="">-- Choose --</option>
    <option value="{{ siteRoot }}/2026-uruguay/en/">Summary of Talks — AI-generated report of main ideas from all the talks</option>
    {% for ev in events %}
    <option value="{{ siteRoot }}/2026-uruguay/en/{{ ev.folder }}/">{% eventLabel ev, "en" %}</option>
    {% endfor %}
  </select>
</div>

{# ── Language toggle ─────────────────────────────────────────────────────── #}
<div class="lang-toggle">
  <a href="{{ siteRoot }}/2026-uruguay/en/glossary/" class="lang-btn active" role="button" id="btn-en">English<span class="lang-sublabel">Original</span></a>
  <a href="{{ siteRoot }}/2026-uruguay/es/glossary/" class="lang-btn" role="button" id="btn-es">Español<span class="lang-sublabel">IA Traducido</span></a>
  <a href="{{ siteRoot }}/2026-uruguay/ne/glossary/" class="lang-btn" role="button" id="btn-ne">नेपाली<span class="lang-sublabel">AI अनुवादित</span></a>
</div>

<style>
  #content h2 { border-bottom: 1px solid #eee; padding-bottom: 4px; }
