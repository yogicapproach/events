---
layout: false
lang: en
permalink: /en/events/2026-uruguay/search/
title: "Search"
heading: "Search Talks"
description: "Search transcripts of talks by Satchidananda — Uruguay, February 2026."
footerNavHref: /en/events/2026-uruguay/
footerNavLabel: "&#8592; Browse Individual Talks"
---
{% extends "layouts/base.njk" %}

{% block head_extra %}
<link href="{{ '/assets/2026-uruguay/pagefind/pagefind-ui.css' | url }}" rel="stylesheet">
<style>
  #search { max-width: 800px; margin: 1.5em auto; }
  .search-lang-filters { max-width: 800px; margin: 0 auto 1em; display: flex; gap: 0.5em; flex-wrap: wrap; align-items: center; }
  .search-lang-filters span { font-size: 0.9em; color: #555; margin-right: 0.25em; }
</style>
{% endblock %}

{% block body %}
  <div class="search-lang-filters" data-pagefind-ignore>
    <span>Filter by language:</span>
    <a class="lang-btn active" aria-pressed="true"  href="/en/events/2026-uruguay/search/">English</a>
    <a class="lang-btn"        aria-pressed="false" href="/es/events/2026-uruguay/search/">Español</a>
    <a class="lang-btn"        aria-pressed="false" href="/ne/events/2026-uruguay/search/">नेपाली</a>
  </div>
  <div id="search" data-pagefind-ignore></div>
{% endblock %}

{% block scripts %}
<script src="{{ '/assets/2026-uruguay/pagefind/pagefind-ui.js' | url }}"></script>
<script>
  window.addEventListener('DOMContentLoaded', function() {
    new PagefindUI({
      element: '#search',
      baseUrl: '/',
      showImages: false,
      filters: { language: 'en' }
    });
    if (typeof updateTopbar === 'function') updateTopbar('en');
  });
</script>
{% endblock %}
